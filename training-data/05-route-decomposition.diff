-/** Get today's date as YYYY-MM-DD in the given IANA timezone (falls back to UTC) */
-function getTodayInZone(tz: string): string {
-  try {
-    return new Intl.DateTimeFormat('en-CA', {
-      timeZone: tz, year: 'numeric', month: '2-digit', day: '2-digit',
-    }).format(new Date());
-  } catch (err) {
-    logger.debug({ err }, "[timezone] Invalid timezone for getTodayInZone — falling back to UTC");
-    return new Date().toISOString().slice(0, 10);
-  }
-}
-
-/** Get yesterday's date as YYYY-MM-DD in the given IANA timezone (falls back to UTC) */
-function getYesterdayInZone(tz: string): string {
-  const d = new Date();
-  d.setDate(d.getDate() - 1);
-  try {
-    return new Intl.DateTimeFormat('en-CA', {
-      timeZone: tz, year: 'numeric', month: '2-digit', day: '2-digit',
-    }).format(d);
-  } catch (err) {
-    logger.debug({ err }, "[timezone] Invalid timezone for getYesterdayInZone — falling back to UTC");
-    d.setUTCDate(d.getUTCDate());
-    return d.toISOString().slice(0, 10);
-  }
-}
