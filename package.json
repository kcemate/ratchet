{
  "name": "@ratchet-run/cli",
  "version": "1.0.0",
  "description": "Autonomous iterative code improvement CLI — write tests, fix bugs, harden code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ratchet": "dist/index.js"
  },
  "files": [
    "dist/",
    "action/",
    "README.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "ai",
    "code-improvement",
    "automation",
    "testing",
    "ratchet",
    "devops",
    "claude"
  ],
  "author": "Ratchet Team",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ratchet-run/ratchet.git"
  },
  "homepage": "https://github.com/ratchet-run/ratchet#readme",
  "bugs": {
    "url": "https://github.com/ratchet-run/ratchet/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "yaml": "^2.8.2"
  }
}
